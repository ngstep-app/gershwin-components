#!/bin/sh
### BEGIN INIT INFO
# Provides:          dshelper
# Required-Start:    $remote_fs $syslog rpcbind
# Required-Stop:     $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Gershwin Directory Services Helper
# Description:       Provides user/group lookups for NSS via plist files
### END INIT INFO

PATH=/sbin:/usr/sbin:/bin:/usr/bin:/System/Library/Tools
NAME=dshelper
DAEMON=/System/Library/Tools/dshelper
PIDFILE=/var/run/dshelper.pid

# Source GNUstep environment
. /System/Library/Makefiles/GNUstep.sh

[ -x "$DAEMON" ] || exit 0

case "$1" in
    start)
        echo "Starting $NAME"
        if [ -f "$PIDFILE" ]; then
            echo "$NAME already running."
            exit 1
        fi
        # Start gdomap if not already running (required for distributed objects)
        if ! pgrep gdomap; then
            echo "Starting gdomap"
            /System/Library/Tools/gdomap
        fi
        $DAEMON
        ;;
    stop)
        echo "Stopping $NAME"
        if [ -f "$PIDFILE" ]; then
            kill $(cat "$PIDFILE") 2>/dev/null
            rm -f "$PIDFILE"
        fi
        # Stop gdomap if running
        if pgrep gdomap; then
            echo "Stopping gdomap"
            pkill gdomap
        fi
        ;;
    restart|force-reload)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 $(cat "$PIDFILE") 2>/dev/null; then
            echo "$NAME is running."
            exit 0
        else
            echo "$NAME is not running."
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|force-reload|status}"
        exit 1
        ;;
esac

exit 0
