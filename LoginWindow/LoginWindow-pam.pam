# PAM configuration for Gershwin LoginWindow
# This file must be installed as /etc/pam.d/LoginWindow-pam
# Note: X11 authorization is handled via libXau, not pam_xauth

# Authentication
auth        required    pam_unix.so

# Account management
account     required    pam_unix.so

# Session management
session     required    pam_unix.so
session     required    pam_env.so
session     optional    pam_systemd.so

# Password management
password    required    pam_unix.so
